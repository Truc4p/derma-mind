# Environment Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=your-mongodb-uri-here

# Frontend URL
FRONTEND_URL=http://localhost:3004

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads